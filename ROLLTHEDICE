<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>I AIN'T CINEPHILE — ROLL THE DICE</title>
<link rel="preconnect" href="https://cdn.jsdelivr.net">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/quiple/galmuri@1.1/dist/galmuri.css">
<style>
  :root{
    --bg:#050507;
    --grid:#1a1330;
    --cyan:#4de1f2;
    --cyan-dim:#1d5c66;
    --pink:#ee2a7b;
    --orange:#ffa733;
    --text:#f3f1e9;
    --dim:#8a8698;
    --panel:#0c0b12;
  }
  *{box-sizing:border-box;}
  html,body{
    margin:0; padding:0; height:100%;
    background:var(--bg);
    color:var(--text);
    font-family:"Galmuri11","Galmuri9",monospace;
    overflow:hidden;
    -webkit-font-smoothing:none;
  }
  body{
    display:flex; align-items:center; justify-content:center;
    position:relative;
  }

  /* ---------- retro horizon backdrop ---------- */
  .backdrop{
    position:fixed; inset:0; z-index:0; overflow:hidden;
    background:
      radial-gradient(ellipse at 50% 62%, rgba(238,42,123,0.16), transparent 60%),
      linear-gradient(180deg, #050507 0%, #050507 55%, #0d0616 100%);
  }
  .sun{
    position:absolute; left:50%; top:34%;
    width:340px; height:340px; margin-left:-170px;
    border-radius:50%;
    background:linear-gradient(180deg, var(--orange) 0%, var(--pink) 55%, #6a1a52 100%);
    filter:blur(2px);
    opacity:.55;
    box-shadow:0 0 120px 20px rgba(238,42,123,0.25);
  }
  .sun::before{
    content:"";
    position:absolute; inset:0;
    background:repeating-linear-gradient(0deg, transparent 0 6px, var(--bg) 6px 12px);
    opacity:.7;
  }
  .horizon{
    position:absolute; left:0; right:0; top:60%; height:1px;
    background:var(--cyan);
    box-shadow:0 0 12px 1px var(--cyan);
    opacity:.6;
  }
  .grid{
    position:absolute; left:0; right:0; top:60%; bottom:0;
    background-image:
      linear-gradient(var(--grid) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid) 1px, transparent 1px);
    background-size:60px 60px;
    transform:perspective(220px) rotateX(60deg);
    transform-origin:top;
    opacity:.55;
  }
  .scanlines{
    position:fixed; inset:0; z-index:5; pointer-events:none;
    background:repeating-linear-gradient(0deg, rgba(0,0,0,0.18) 0 1px, transparent 1px 3px);
    mix-blend-mode:overlay;
    opacity:.5;
  }
  .vignette{
    position:fixed; inset:0; z-index:5; pointer-events:none;
    box-shadow: inset 0 0 180px 60px rgba(0,0,0,.85);
  }

  /* ---------- stage ---------- */
  .stage{
    position:relative; z-index:2;
    width:100%; max-width:520px;
    padding:32px 24px 40px;
    display:flex; flex-direction:column; align-items:center;
    gap:22px;
  }

  .logo{
    width:100%; max-width:400px;
    filter:drop-shadow(0 0 18px rgba(77,225,242,.35)) drop-shadow(0 0 30px rgba(238,42,123,.2));
    animation:flicker 5s infinite;
    user-select:none; -webkit-user-drag:none;
  }
  @keyframes flicker{
    0%,96%,100%{opacity:1;}
    97%{opacity:.85;}
    98%{opacity:1;}
    99%{opacity:.9;}
  }

  .tagline{
    text-align:center;
    font-size:13px;
    line-height:1.9;
    color:var(--cyan);
    letter-spacing:.5px;
    text-shadow:0 0 8px rgba(77,225,242,.5);
    min-height:2.6em;
  }

  /* ---------- screens ---------- */
  .screen{ width:100%; display:flex; flex-direction:column; align-items:center; gap:22px; }
  .hidden{ display:none !important; }

  /* ---------- dial ---------- */
  .dial-wrap{
    position:relative;
    width:min(72vw, 300px); height:min(72vw, 300px);
  }
  svg.dial-svg{ width:100%; height:100%; overflow:visible; }
  .dial-disc{
    transform-origin:150px 150px;
    transition:transform 3.4s cubic-bezier(.15,.75,.13,1);
  }
  .seg-label{
    font-family:"Galmuri9",monospace;
    font-size:18px;
    fill:var(--bg);
    text-anchor:middle;
    dominant-baseline:middle;
  }
  .pointer{
    filter:drop-shadow(0 0 6px var(--pink));
  }
  .hub-btn{ cursor:pointer; }
  .hub-btn:hover .hub-circle{ filter:brightness(1.2); }
  .hub-btn:active .hub-circle{ filter:brightness(.9); }
  .hub-text{
    font-family:"Galmuri9",monospace;
    font-size:15px;
    fill:var(--bg);
    text-anchor:middle;
    dominant-baseline:middle;
    pointer-events:none;
  }
  .dial-disc.spinning .hub-btn{ cursor:default; }

  /* ---------- result ---------- */
  .result-icon{ font-size:56px; line-height:1; filter:drop-shadow(0 0 14px rgba(238,42,123,.5)); }
  .result-word{
    font-size:34px;
    letter-spacing:2px;
    color:var(--orange);
    text-shadow:0 0 14px rgba(255,167,51,.6), 0 0 2px rgba(0,0,0,.8);
  }
  .result-sub{ font-size:12px; color:var(--dim); letter-spacing:.5px; }

  /* ---------- buttons ---------- */
  .btn{
    appearance:none; border:none; cursor:pointer;
    font-family:"Galmuri11","Galmuri9",monospace;
    font-size:14px; letter-spacing:1px;
    padding:16px 30px;
    color:var(--bg);
    background:linear-gradient(180deg, var(--cyan), var(--cyan-dim));
    border:2px solid var(--cyan);
    box-shadow:0 0 0 2px #000 inset, 0 0 16px rgba(77,225,242,.45);
    transition:transform .12s ease, box-shadow .12s ease;
  }
  .btn:hover{ transform:translateY(-2px); box-shadow:0 0 0 2px #000 inset, 0 0 22px rgba(77,225,242,.7); }
  .btn:active{ transform:translateY(0); }
  .btn:disabled{
    cursor:default; opacity:.55; transform:none;
    box-shadow:0 0 0 2px #000 inset;
  }
  .btn.pink{
    background:linear-gradient(180deg, var(--pink), #7a0f45);
    border-color:var(--pink);
    box-shadow:0 0 0 2px #000 inset, 0 0 16px rgba(238,42,123,.5);
  }
  .btn.pink:hover{ box-shadow:0 0 0 2px #000 inset, 0 0 22px rgba(238,42,123,.8); }

  /* ---------- timer ---------- */
  .timer-box{ display:flex; flex-direction:column; align-items:center; gap:10px; }
  .timer-clock{
    font-size:46px; letter-spacing:3px; color:var(--pink);
    text-shadow:0 0 16px rgba(238,42,123,.6);
    font-variant-numeric:tabular-nums;
  }
  .timer-ring{ position:relative; width:150px; height:150px; }
  .timer-ring svg{ width:100%; height:100%; transform:rotate(-90deg); }
  .timer-ring circle{ fill:none; stroke-width:8; }
  .ring-bg{ stroke:#1c1a24; }
  .ring-fg{ stroke:var(--pink); stroke-linecap:round; filter:drop-shadow(0 0 6px var(--pink)); transition:stroke-dashoffset 1s linear; }
  .ring-label{
    position:absolute; inset:0; display:flex; align-items:center; justify-content:center;
    font-size:32px; color:var(--text); font-variant-numeric:tabular-nums;
    text-shadow:0 0 10px rgba(77,225,242,.4);
  }
  .status-text{ font-size:12px; color:var(--dim); letter-spacing:1px; min-height:1.4em; }

  @media (max-width:380px){
    .logo{ max-width:300px; }
    .result-word{ font-size:26px; }
  }
</style>
</head>
<body>

  <div class="backdrop">
    <div class="sun"></div>
    <div class="grid"></div>
    <div class="horizon"></div>
  </div>
  <div class="scanlines"></div>
  <div class="vignette"></div>

  <main class="stage">
    <img class="logo" src="data:image/png;base64," alt="I AIN'T CINEPHILE" draggable="false">

    <!-- ===================== SCREEN 1 : START / DIAL ===================== -->
    <section id="screen-start" class="screen">
      <p class="tagline" id="tagline-text">다이얼을 돌려서<br>그림, 말, 행동 중 하나를 뽑으세요.</p>

      <div class="dial-wrap">
        <svg class="dial-svg" viewBox="0 0 300 300">
          <defs>
            <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur stdDeviation="3" result="blur"/>
              <feMerge>
                <feMergeNode in="blur"/>
                <feMergeNode in="SourceGraphic"/>
              </feMerge>
            </filter>
          </defs>

          <!-- outer ring ticks -->
          <circle cx="150" cy="150" r="142" fill="none" stroke="#1c1a24" stroke-width="2"/>

          <!-- pointer (fixed, at top) -->
          <g class="pointer">
            <polygon points="150,4 138,30 162,30" fill="var(--pink)"/>
          </g>

          <!-- rotating disc -->
          <g class="dial-disc" id="dial-disc" filter="url(#glow)">
            <circle cx="150" cy="150" r="128" fill="var(--panel)" stroke="var(--cyan)" stroke-width="3"/>

            <!-- segment dividers -->
            <line x1="150" y1="150" x2="150" y2="22"  stroke="var(--cyan)" stroke-width="2" transform="rotate(60 150 150)"/>
            <line x1="150" y1="150" x2="150" y2="22"  stroke="var(--cyan)" stroke-width="2" transform="rotate(180 150 150)"/>
            <line x1="150" y1="150" x2="150" y2="22"  stroke="var(--cyan)" stroke-width="2" transform="rotate(300 150 150)"/>

            <!-- segment fills (alternating tint) -->
            <path d="M150,150 L39.2,86 A128,128 0 0,1 260.8,86 Z" fill="rgba(238,42,123,0.12)"/>
            <path d="M150,150 L260.8,86 A128,128 0 0,1 150,278 Z" fill="rgba(255,167,51,0.10)"/>
            <path d="M150,150 L150,278 A128,128 0 0,1 39.2,86 Z" fill="rgba(77,225,242,0.10)"/>

            <!-- labels -->
            <text class="seg-label" x="150" y="66"  fill="var(--text)" transform="rotate(0 150 150)">그림</text>
            <text class="seg-label" x="150" y="66"  fill="var(--text)" transform="rotate(120 150 150)">말</text>
            <text class="seg-label" x="150" y="66"  fill="var(--text)" transform="rotate(240 150 150)">행동</text>

            <!-- hub / click target -->
            <g class="hub-btn" id="hub-btn">
              <circle class="hub-circle" cx="150" cy="150" r="46" fill="var(--cyan)" stroke="#000" stroke-width="2"/>
              <text class="hub-text" x="150" y="150">START</text>
            </g>
          </g>
        </svg>
      </div>

      <p class="status-text" id="start-status">다이얼 가운데를 눌러 시작</p>
    </section>

    <!-- ===================== SCREEN 2 : RESULT ===================== -->
    <section id="screen-result" class="screen hidden">
      <div class="result-icon" id="result-icon">🎨</div>
      <div class="result-word" id="result-word">그림</div>
      <div class="result-sub">가 나왔습니다</div>

      <button class="btn pink" id="timer-start-btn">1분 타이머 시작</button>

      <div class="timer-box hidden" id="timer-box">
        <div class="timer-ring">
          <svg viewBox="0 0 120 120">
            <circle class="ring-bg" cx="60" cy="60" r="52"/>
            <circle class="ring-fg" id="ring-fg" cx="60" cy="60" r="52"
                    stroke-dasharray="326.7" stroke-dashoffset="0"/>
          </svg>
          <div class="ring-label" id="timer-clock">1:00</div>
        </div>
        <div class="status-text" id="timer-status">진행 중...</div>
      </div>

      <button class="btn hidden" id="retry-btn">다시 하기</button>
    </section>
  </main>

<script>
(function(){
  const CATEGORIES = [
    { key:'그림', icon:'🎨' },
    { key:'말',   icon:'💬' },
    { key:'행동', icon:'🕺' }
  ];
  const SEG_ANGLE = { '그림':0, '말':120, '행동':240 };

  const screenStart  = document.getElementById('screen-start');
  const screenResult = document.getElementById('screen-result');
  const dialDisc      = document.getElementById('dial-disc');
  const hubBtn         = document.getElementById('hub-btn');
  const startStatus     = document.getElementById('start-status');

  const resultIcon = document.getElementById('result-icon');
  const resultWord = document.getElementById('result-word');
  const timerStartBtn = document.getElementById('timer-start-btn');
  const timerBox = document.getElementById('timer-box');
  const timerClock = document.getElementById('timer-clock');
  const timerStatus = document.getElementById('timer-status');
  const ringFg = document.getElementById('ring-fg');
  const retryBtn = document.getElementById('retry-btn');

  const RING_CIRC = 326.7; // 2*PI*52
  let currentRotation = 0;
  let spinning = false;
  let timerInterval = null;

  function spin(){
    if(spinning) return;
    spinning = true;
    startStatus.textContent = '두구두구두구...';

    const choice = CATEGORIES[Math.floor(Math.random() * 3)];
    const segAngle = SEG_ANGLE[choice.key];
    const extraSpins = 5; // full rotations for effect
    const targetMod = (360 - segAngle) % 360;

    // ensure rotation always increases (never spins backward visually)
    const base = Math.floor(currentRotation / 360) * 360;
    let target = base + extraSpins * 360 + targetMod;
    if(target <= currentRotation) target += 360;

    currentRotation = target;
    dialDisc.style.transform = `rotate(${currentRotation}deg)`;

    window.setTimeout(() => {
      spinning = false;
      showResult(choice);
    }, 3500);
  }

  function showResult(choice){
    resultIcon.textContent = choice.icon;
    resultWord.textContent = choice.key;
    screenStart.classList.add('hidden');
    screenResult.classList.remove('hidden');
    timerStartBtn.classList.remove('hidden');
    timerBox.classList.add('hidden');
    retryBtn.classList.add('hidden');
  }

  hubBtn.addEventListener('click', spin);

  timerStartBtn.addEventListener('click', () => {
    timerStartBtn.classList.add('hidden');
    timerBox.classList.remove('hidden');
    startCountdown(60);
  });

  function startCountdown(totalSeconds){
    let remaining = totalSeconds;
    updateClock(remaining);
    ringFg.style.strokeDasharray = RING_CIRC;
    ringFg.style.strokeDashoffset = 0;
    timerStatus.textContent = '진행 중...';

    timerInterval = window.setInterval(() => {
      remaining -= 1;
      updateClock(remaining);
      const offset = RING_CIRC * (1 - remaining / totalSeconds);
      ringFg.style.strokeDashoffset = offset;

      if(remaining <= 0){
        window.clearInterval(timerInterval);
        timerStatus.textContent = '종료!';
        retryBtn.classList.remove('hidden');
      }
    }, 1000);
  }

  function updateClock(sec){
    const s = Math.max(0, sec);
    const m = Math.floor(s / 60);
    const r = s % 60;
    timerClock.textContent = m + ':' + String(r).padStart(2,'0');
  }

  retryBtn.addEventListener('click', () => {
    if(timerInterval) window.clearInterval(timerInterval);
    screenResult.classList.add('hidden');
    screenStart.classList.remove('hidden');
    startStatus.textContent = '다이얼 가운데를 눌러 시작';
  });

})();
</script>
</body>
</html>
