<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>I AIN'T CINEPHILE</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <canvas id="particles"></canvas>

  <div class="grid-bg"></div>

  <main class="container">
    <h1 class="title">I AIN'T CINEPHILE</h1>

    <div class="spinner-wrapper">
      <div class="pointer"></div>

      <div id="spinner" class="spinner">
        <div class="sector draw"><span>🎨 DRAW</span></div>
        <div class="sector act"><span>💃 ACT</span></div>
        <div class="sector explain"><span>😃 EXPLAIN</span></div>
      </div>

      <button id="startBtn" class="center-btn">START</button>
    </div>

    <section id="resultSection" class="result-section hidden">
      <div id="resultCard" class="result-card">
        <div id="resultIcon" class="result-icon"></div>
        <h2 id="resultText"></h2>
        <p id="resultDesc"></p>
      </div>

      <button id="actionBtn" class="neon-btn">READY, ACTION!</button>

      <div id="timerSection" class="timer-section hidden">
        <div id="timer" class="timer">01:00</div>
        <button id="cancelBtn" class="cancel-btn">CANCEL</button>
      </div>

      <button id="rollAgainBtn" class="roll-btn hidden">ROLL AGAIN?</button>
    </section>
  </main>

  <script src="script.js"></script>
</body>
</html>
